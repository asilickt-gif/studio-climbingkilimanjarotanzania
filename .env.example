# projectId/dataset are currently hardcoded in sanity.config.ts and
# sanity.cli.ts, so the Studio dev server doesn't require this file to run.
# These are here for scripts/CI that need the project/dataset without
# importing the Studio config, or if that config is later externalized.
SANITY_STUDIO_PROJECT_ID=19nbwjcc
SANITY_STUDIO_DATASET=production

# Auth for the Studio itself is handled interactively via `npx sanity login`.
# The seed scripts in scripts/ likewise authenticate via the CLI user
# session (`npx sanity exec <script> --with-user-token`), not an env token.
